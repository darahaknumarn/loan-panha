<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
        <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="CamITSo.My.MySettings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
        </sectionGroup>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="CamITSo.My.MySettings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <connectionStrings>
        <add name="CamITSo.My.MySettings.ktv" connectionString="Dsn=ktv;uid=sa"
            providerName="System.Data.Odbc" />
        <add name="CamITSo.My.MySettings.BarCodeConnectionString" connectionString="Data Source=ONEWINDOW;Initial Catalog=BarCode;User ID=sa"
            providerName="System.Data.SqlClient" />
        <add name="CamITSo.My.MySettings.ConnectionString" connectionString="Data Source=monyroth-pc;Integrated Security=True"
            providerName="System.Data.SqlClient" />
        <add name="CamITSo.My.MySettings.barcodeConnectionString1" connectionString="Data Source=ADMIN;Initial Catalog=barcode;User ID=sa;Password=123456"
            providerName="System.Data.SqlClient" />
        <add name="CamITSo.My.MySettings.BarCodeConnectionString2" connectionString="Data Source=USER-PC\SQLEXPRESS;Initial Catalog=BarCode;User ID=sa;Password=123456"
            providerName="System.Data.SqlClient" />
        <add name="CamITSo.My.MySettings.BarCodeConnectionString3" connectionString="Data Source=.;Initial Catalog=BarCode;Persist Security Info=True;User ID=sa;Password=123456"
            providerName="System.Data.SqlClient" />
        <add name="CamITSo.My.MySettings.BARCODEConnectionString4" connectionString="Data Source=.;Initial Catalog=BARCODE;Integrated Security=True"
            providerName="System.Data.SqlClient" />
    </connectionStrings>
    <system.diagnostics>
        <sources>
            <!-- This section defines the logging configuration for My.Application.Log -->
            <source name="DefaultSource" switchName="DefaultSwitch">
                <listeners>
                    <add name="FileLog"/>
                    <!-- Uncomment the below section to write to the Application Event Log -->
                    <!--<add name="EventLog"/>-->
                </listeners>
            </source>
        </sources>
        <switches>
            <add name="DefaultSwitch" value="Information" />
        </switches>
        <sharedListeners>
            <add name="FileLog"
                 type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL"
                 initializeData="FileLogWriter"/>
            <!-- Uncomment the below section and replace APPLICATION_NAME with the name of your application to write to the Application Event Log -->
            <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
        </sharedListeners>
    </system.diagnostics>
    <applicationSettings>
        <CamITSo.My.MySettings>
            <setting name="textBox" serializeAs="String">
                <value>0</value>
            </setting>
            <setting name="Setting" serializeAs="String">
                <value />
            </setting>
            <setting name="IP" serializeAs="String">
                <value />
            </setting>
            <setting name="SaveSetting1" serializeAs="String">
                <value>0</value>
            </setting>
            <setting name="LastUpdated" serializeAs="String">
                <value />
            </setting>
        </CamITSo.My.MySettings>
    </applicationSettings>
    <userSettings>
        <CamITSo.My.MySettings>
            <setting name="SaveSetting" serializeAs="String">
                <value>0</value>
            </setting>
            <setting name="GetDate" serializeAs="String">
                <value />
            </setting>
        </CamITSo.My.MySettings>
    </userSettings>
</configuration>
